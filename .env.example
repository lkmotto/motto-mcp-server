# Neon Postgres connection string. Required.
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/motto_fleet?sslmode=require

# Shared bearer token presented by variable agents in `Authorization: Bearer <token>`.
# Generate once (e.g. `openssl rand -hex 32`) and put in Doppler / Northflank shared group.
# Currently informational — auth middleware is a TODO; v0 relies on private networking.
MOTTO_MCP_AUTH_TOKEN=replace-me-with-a-long-random-token

# HTTP listen port. Northflank/Maritime sets this automatically.
PORT=8080

# Mount domain-specific sub-servers (grabber, northflank, doppler, cloudflare).
# Set to 1 to expose grabber.enqueue_rotation, grabber.grabber_health, etc.
# as namespaced MCP tools. Requires DATABASE_URL to be set.
MOTTO_MCP_MOUNT_DOMAIN_SERVERS=1
